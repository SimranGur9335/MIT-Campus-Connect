rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerifiedEmail() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Role Helpers (Note: We use get() for trusted role check)
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }
    function isAdmin() { return hasRole('ADMIN'); }
    function isFaculty() { return hasRole('FACULTY'); }
    function isClubHead() { return hasRole('CLUB_HEAD'); }

    // --- COLLECTION: USERS ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'department'])
          && data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 256
          && data.role in ['STUDENT', 'FACULTY', 'CLUB_HEAD', 'ADMIN']
          && data.department is string && data.department.size() <= 100;
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() 
        && isValidUser(incoming())
        && incoming().role == 'STUDENT'; // Default role for self-reg

      allow update: if (
        isSignedIn() && userId == request.auth.uid && (
          // Allow personal updates for non-critical fields
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'department', 'updatedAt'])
          && incoming().updatedAt == request.time
        )
      ) || isAdmin();
    }

    // --- COLLECTION: ANNOUNCEMENTS ---
    match /announcements/{announcementId} {
      function isValidAnnouncement(data) {
        return data.keys().hasAll(['title', 'content', 'category', 'status', 'authorId'])
          && data.title is string && data.title.size() <= 200
          && data.content is string && data.content.size() <= 10000
          && data.category in ['Academics', 'Placements', 'Sports', 'Clubs', 'Seminars', 'Events', 'Transport', 'Emergency']
          && data.status in ['pending', 'published']
          && data.authorId == request.auth.uid;
      }

      allow read: if isSignedIn() && (existing().status == 'published' || isAdmin() || existing().authorId == request.auth.uid);

      allow create: if isVerifiedEmail() 
        && (isAdmin() || isFaculty() || isClubHead())
        && isValidAnnouncement(incoming())
        && (isAdmin() ? true : incoming().status == 'pending') // Non-admins must queue for approval
        && incoming().createdAt == request.time;

      allow update: if isVerifiedEmail() && (
        isAdmin() || (
          existing().authorId == request.auth.uid 
          && isValidAnnouncement(incoming())
          && incoming().authorId == existing().authorId
          && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'category', 'status', 'updatedAt'])
              && (isAdmin() ? true : incoming().status == 'pending'))
          && incoming().updatedAt == request.time
        )
      );

      allow delete: if isAdmin() || (isVerifiedEmail() && existing().authorId == request.auth.uid);
    }

    // --- COLLECTION: NOTIFICATIONS ---
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isSignedIn() && userId == request.auth.uid;
    }

    // --- COLLECTION: ACTIVITY LOGS ---
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().timestamp == request.time;
    }
  }
}
