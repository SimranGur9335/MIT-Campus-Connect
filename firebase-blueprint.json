{
  "entities": {
    "User": {
      "title": "User",
      "description": "Campus user profile with role and department",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["STUDENT", "FACULTY", "CLUB_HEAD", "ADMIN"] },
        "department": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "department"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Campus announcement notice",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Academics", "Placements", "Sports", "Clubs", "Seminars", "Events", "Transport", "Emergency"] },
        "department": { "type": "string" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "URGENT"] },
        "status": { "type": "string", "enum": ["pending", "published"] },
        "expiresAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category", "authorId", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User specific real-time notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "relatedId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "System activity log for auditing",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Campus announcements"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User private notifications"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Global activity logs"
    }
  }
}
